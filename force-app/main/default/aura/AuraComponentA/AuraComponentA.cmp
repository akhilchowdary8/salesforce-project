<aura:component implements="flexipage:availableForAllPageTypes" access="global">
  <aura:attribute name="message" type="String" default="SXD" />
  <aura:attribute name="messagereceived" type="String" default="S" />
  <lightning:messageChannel
    type="SampleMessage__c"
    aura:id="SampleMessage1"
    onMessage="{!c.handleMessage}"
  />
  <input label="Message" value="{!v.message}" onkeyup="{!c.savetext}" />
  <lightning:button label="publish" onclick="{!c.sendMessage}" />
  <lightning:card title="Aura Component A">
    <p>Message Received: {!v.messagereceived}</p>
  </lightning:card>
</aura:component>